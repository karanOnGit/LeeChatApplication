# Go backend (LeeBackend). REST + GraphQL are proxied through Next.js
# rewrites (see next.config.js) so the browser only talks same-origin.
BACKEND_URL=http://localhost:3000

# Frontend-visible endpoints (relative — proxied to BACKEND_URL)
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_GRAPHQL_URL=/api/graphql

# WebSocket connects directly to the backend (auth via ?token= query param)
NEXT_PUBLIC_WS_URL=ws://localhost:3000/ws
